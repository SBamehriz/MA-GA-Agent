# Copy this file to `.env` and adjust if needed.
# All variables here are optional — the system has safe defaults for every value.

# --- Local model (qwen3:8b via Ollama) ---------------------------------------
# Where the local Ollama server is listening.
# Default: http://localhost:11434
LOCAL_MODEL_ENDPOINT=http://localhost:11434

# Model tag, must already be pulled with `ollama pull qwen3:8b`.
# Default: qwen3:8b
LOCAL_MODEL_NAME=qwen3:8b

# Per-request timeout in milliseconds. Bump this if you are CPU-only.
# Default: 120000 (= 2 minutes)
LOCAL_MODEL_TIMEOUT_MS=120000
